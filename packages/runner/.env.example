# Runner network
# RUNNER_PORT takes precedence over PORT
RUNNER_PORT=3000
# PORT=3000
HOST=127.0.0.1

# Playwright
HEADLESS=false
SLOW_MO=60

# Planner
# Options: mock | anthropic | openai | ollama
PLANNER_PROVIDER=mock

# Optional explicit local config path for provider settings written by the runner.
# If omitted, the runner uses packages/runner/.local/planner-config.json
# RUNNER_CONFIG_PATH=C:\path\to\planner-config.json

# Anthropic fallback defaults
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-6

# OpenAI fallback defaults
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Ollama fallback defaults
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.1

# Assist mode
# Model used for /assist/extract when set; otherwise the planner model is reused.
# ASSIST_MODEL=claude-opus-4-6
