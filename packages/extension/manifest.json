{
  "manifest_version": 3,
  "name": "Browser Automation Assistant",
  "short_name": "AutoAssist",
  "version": "0.1.0",
  "description": "Local-first AI browser automation. All processing runs on your machine via a localhost runner — no data leaves your device.",
  "homepage_url": "https://github.com/joarb/browser-automation",
  "permissions": [
    "activeTab",
    "nativeMessaging",
    "scripting",
    "sidePanel",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "type": "module",
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Automation Panel"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
